{
  "name": "obsidian-jenn-bridge",
  "version": "1.0.0",
  "description": "Jenn → Obsidian Bridge: WebSocket client for receiving notes from Jenn Core",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "lint": "eslint ."
  },
  "keywords": [
    "obsidian",
    "jenn",
    "websocket",
    "plugin"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.15.17",
    "esbuild": "0.25.5",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.4.0",
    "globals": "^17.6.0",
    "obsidian": "^1.0.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.1"
  }
}
